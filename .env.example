# Public web/mobile runtime config. Do not put secrets here: Flutter Web embeds
# these values in the browser bundle at build time.
API_URL='https://murya.example.com/api'

# Optional legacy websocket URL if this channel is re-enabled in the app.
SOCKET_URL='wss://murya.example.com/websocket'

# PostHog
POSTHOG_ENABLED='false'
POSTHOG_PROJECT_API_KEY=''
# Keep the ingest proxy on the primary domain so the landing and the web app
# share the same analytics entrypoint.
POSTHOG_PROXY_HOST='https://murya.example.com/ingest'
POSTHOG_REPLAY_ENABLED='false'
POSTHOG_DEBUG='false'

# Required by the current authentication bootstrap.
# Replace with an existing Job UUID from the seeded database.
DEFAULT_JOB_ID='replace-with-existing-job-id'
